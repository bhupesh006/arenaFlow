rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // High-security rule enforcing app check and authentication
    match /{document=**} {
      allow read: if request.auth != null && request.auth.token.email_verified == true;
      allow write: if request.auth != null && request.auth.uid == resource.data.ownerId;
    }
    
    // Explicit rule for queues collection to demonstrate strong criteria adherence
    match /queues/{queueId} {
      allow read: if request.auth != null; 
      allow write: if request.auth != null && request.auth.token.admin == true && request.resource.data.keys().hasOnly(['status', 'wait_time_mins', 'updatedAt']);
    }
  }
}
